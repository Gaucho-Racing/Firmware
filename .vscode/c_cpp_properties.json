{
    "configurations": [
        {
            "name": "ECU (STM32G4)",
            "includePath": [
                "${workspaceFolder}/ECU/**",
                "${workspaceFolder}/lib/**",
                "${workspaceFolder}/lib/CMSIS/Device/ST/STM32G4xx/Include",
                "${workspaceFolder}/lib/CMSIS/Include",
                "${workspaceFolder}/lib/CMSIS/Core/Include",
                "${workspaceFolder}/ECU/Core/Inc",
                "${workspaceFolder}/ECU/Application/Inc",
                "${workspaceFolder}/lib/STM32G4xx_HAL_Driver/Inc",
                "${workspaceFolder}/lib/STM32G4xx_HAL_Driver/Inc/Legacy"
            ],
            "defines": [
                "USE_HAL_DRIVER",
                "STM32G474xx"
            ],
            "compilerPath": "/usr/bin/arm-none-eabi-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "compileCommands": "${workspaceFolder}/ECU/build/compile_commands.json",
            "configurationProvider": "ms-vscode.cmake-tools",
            "intelliSenseMode": "gcc-arm"
        },
        {
            "name": "DashPanel (STM32U5)",
